{
  "manifest_version": 3,
  "name": "Helios",
  "version": "1.0.0",
  "description": "AI assistant powered by Groq - Analyze screenshots with AI",
  "permissions": [
    "contextMenus",
    "storage",
    "unlimitedStorage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://api.groq.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Helios - AI Assistant"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "helios@example.com",
      "strict_min_version": "113.0",
      "data_collection_permissions": {
        "required": ["websiteContent"],
        "optional": ["technicalAndInteraction"]
      }
    }
  }
}
